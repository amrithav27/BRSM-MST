```{r}
library(tidyverse)

############################################
# Response distribution
############################################

ggplot(df_both_test, aes(x = response_type)) +
  geom_bar(fill = "darkorange") +
  labs(
    title = "Distribution of Responses",
    x = "Response Type",
    y = "Count"
  ) +
  theme_minimal()

############################################
# Stimulus × Response confusion plot
############################################

ggplot(df_both_test, aes(x = stimulus_type, fill = response_type)) +
  geom_bar(position = "dodge") +
  labs(
    title = "Responses by Stimulus Type",
    x = "Stimulus Type",
    y = "Count",
    fill = "Response"
  ) +
  theme_minimal()

############################################
# Reaction time distribution
############################################

ggplot(df_both_test, aes(x = trials.key_resp_3.rt)) +
  geom_histogram(bins = 40, fill = "purple", alpha = 0.7) +
  labs(
    title = "Reaction Time Distribution",
    x = "Reaction Time (seconds)",
    y = "Count"
  ) +
  theme_minimal()

############################################
# Reaction time by stimulus type
############################################

ggplot(df_both_test,
       aes(x = stimulus_type, y = trials.key_resp_3.rt, fill = stimulus_type)) +
  geom_violin(trim = FALSE, alpha = 0.6) +
  geom_boxplot(width = 0.1, fill = "white") +
  labs(
    title = "Reaction Time Distribution by Stimulus Type",
    x = "Stimulus Type",
    y = "Reaction Time (seconds)"
  ) +
  theme_minimal() +
  theme(legend.position = "none")

############################################
# Position vs Response Type
############################################

ggplot(df_both_test,
       aes(x = factor( response_type), fill = position_of_stimuli)) +
  geom_bar(position = "dodge") +
  labs(
    title = "Responses by Stimulus Position",
    x = "Response",
    y = "Count",
    fill = " Stimulus Position"
  ) +
  theme_minimal()

############################################
# Reaction Time by Stimulus Position
############################################

ggplot(df_both_test,
       aes(x = factor(position_of_stimuli),
           y = trials.key_resp_3.rt,
           fill = factor(position_of_stimuli))) +
  geom_violin(alpha = 0.6) +
  geom_boxplot(width = 0.1, fill = "white") +
  labs(
    title = "Reaction Time by Stimulus Position",
    x = "Stimulus Position",
    y = "Reaction Time (seconds)"
  ) +
  theme_minimal() +
  theme(legend.position = "none")

############################################
# Lure Position vs Response
############################################

ggplot(df_both_test %>% filter(stimulus_type == "Lure"),
       aes(x = factor(position_of_stimuli), fill = response_type)) +
  geom_bar(position = "fill") +
  labs(
    title = "Lure Responses by Similarity Position",
    x = "Lure Position",
    y = "Proportion",
    fill = "Response"
  ) +
  theme_minimal()
###########################################
# Reaction time vs response type
###########################################
ggplot(df_both_test,
       aes(x = response_type, y = trials.key_resp_3.rt, fill = response_type)) +
  geom_violin(alpha = 0.6) +
  geom_boxplot(width = 0.1, fill = "white") +
  labs(
    title = "Reaction Time by Response Type",
    x = "Response",
    y = "Reaction Time (seconds)"
  ) +
  theme_minimal() +
  theme(legend.position = "none")

```

```{r}
library(tidyverse)

############################################
# 1. Compute response probabilities per participant
############################################

participant_probs_both <- df_both_test %>%
  group_by(participant_id) %>%
  summarise(
    
    # Target responses
    p_old_target = mean(stimulus_type == "Target" & response_type == "Old"),
    
    # Lure responses
    p_similar_lure = mean(stimulus_type == "Lure" & response_type == "Similar"),
    
    # Foil responses
    p_old_foil = mean(stimulus_type == "Foil" & response_type == "Old"),
    p_similar_foil = mean(stimulus_type == "Foil" & response_type == "Similar"),
    
    .groups = "drop"
  )

############################################
# 2. Compute MST metrics for BOTH dataset
############################################

mst_metrics_both <- participant_probs_both %>%
  mutate(
    
    # Recognition score
    REC_both = p_old_target - p_old_foil,
    
    # Lure Discrimination Index
    LDI_both = p_similar_lure - p_similar_foil
  ) %>%
  select(participant_id, REC_both, LDI_both)

############################################
# 3. Group-level Mean and SD
############################################

mst_summary_both <- mst_metrics_both %>%
  summarise(
    
    REC_both_mean = mean(REC_both),
    REC_both_sd = sd(REC_both),
    
    LDI_both_mean = mean(LDI_both),
    LDI_both_sd = sd(LDI_both)
  )

############################################
# 4. Format results like in papers
############################################

mst_summary_both_formatted <- mst_summary_both %>%
  mutate(
    REC_both = sprintf("%.3f (%.3f)", REC_both_mean, REC_both_sd),
    LDI_both = sprintf("%.3f (%.3f)", LDI_both_mean, LDI_both_sd)
  ) %>%
  select(REC_both, LDI_both)

############################################
# 5. Print outputs
############################################

cat("Participant-level MST metrics (Both dataset):\n")
print(mst_metrics_both)

cat("\nGroup summary:\n")
print(mst_summary_both)

cat("\nFormatted summary (Mean (SD)):\n")
print(mst_summary_both_formatted)

############################################
# 6. Plot distributions of metrics
############################################

mst_metrics_both %>%
  pivot_longer(cols = c(REC_both, LDI_both),
               names_to = "metric",
               values_to = "value") %>%
  ggplot(aes(x = metric, y = value, fill = metric)) +
  geom_boxplot(alpha = 0.7) +
  theme_minimal() +
  labs(
    title = "MST Metrics Distribution (Both Dataset)",
    x = "Metric",
    y = "Score"
  ) +
  theme(legend.position = "none")
```

### Experiment 2: Only Item
```{r}
# Item Only - Task
library(tidyverse)

item_base_path <- "~/Desktop/Classwork/3-2/Behavioral Research: Statistical Methods/Project/code/MST_Data/item_only"
item_task_path <- file.path(item_base_path, "item_only_data")

############################################
# FIND TASK FILES
############################################

item_task_files <- list.files(
  path = item_task_path,
  pattern = "_MST_task_.*\\.csv$",
  full.names = TRUE
)

cat("Number of ITEM TASK files:", length(item_task_files), "\n")

############################################
# LOAD + CLEAN TASK FILES
############################################

load_item_task <- function(file_path){

  df <- suppressMessages(
    read_csv(file_path, show_col_types = FALSE, name_repair = "unique")
  )

  participant_id <- substr(basename(file_path),1,5)

  if(!"trials.key_resp_9.rt" %in% names(df)) df$trials.key_resp_9.rt <- NA
  if(!"trials.key_resp_8.rt" %in% names(df)) df$trials.key_resp_8.rt <- NA

  df %>%
    filter(!is.na(trials.thisN)) %>%
    select(image_path,
           trials.thisN,
           trials.key_resp_9.rt,
           trials.key_resp_8.rt) %>%
    mutate(
      participant_id = participant_id,
      trial_number = trials.thisN + 1,

      trials.key_resp_9.rt = as.numeric(trials.key_resp_9.rt),
      trials.key_resp_8.rt = as.numeric(trials.key_resp_8.rt),

      rt = case_when(
        !is.na(trials.key_resp_9.rt) ~ trials.key_resp_9.rt * 1000,
        !is.na(trials.key_resp_8.rt) ~ (3 + trials.key_resp_8.rt) * 1000,
        TRUE ~ NA_real_
      ),

      event_position = ((trial_number-1) %% 7) + 1,

      boundary_position = case_when(
        event_position == 1 ~ "Post",
        event_position == 7 ~ "Pre",
        TRUE ~ "Non"
      ),

      image_name = basename(image_path)
    )
}

df_item_task <- map_dfr(item_task_files, load_item_task)

cat("Unique participants:", length(unique(df_item_task$participant_id)), "\n")
table(df_item_task$boundary_position)
summary(df_item_task$rt)
```

