```{r}
library(tidyverse)

############################################
# 1. Compute response probabilities per participant
############################################

participant_probs_task <- df_task_test %>%
  group_by(participant_id) %>%
  summarise(
    
    p_old_target = mean(stimulus_type == "Target" & response_type == "Old"),
    
    p_similar_lure = mean(stimulus_type == "Lure" & response_type == "Similar"),
    
    p_old_foil = mean(stimulus_type == "Foil" & response_type == "Old"),
    
    p_similar_foil = mean(stimulus_type == "Foil" & response_type == "Similar"),
    
    .groups = "drop"
  )

############################################
# 2. Compute MST metrics
############################################

mst_metrics_task <- participant_probs_task %>%
  mutate(
    
    REC_task = p_old_target - p_old_foil,
    
    LDI_task = p_similar_lure - p_similar_foil
  ) %>%
  select(participant_id, REC_task, LDI_task)

############################################
# 3. Group-level Mean and SD
############################################

mst_summary_task <- mst_metrics_task %>%
  summarise(
    
    REC_task_mean = mean(REC_task),
    REC_task_sd = sd(REC_task),
    
    LDI_task_mean = mean(LDI_task),
    LDI_task_sd = sd(LDI_task)
  )

############################################
# 4. Format results
############################################

mst_summary_task_formatted <- mst_summary_task %>%
  mutate(
    REC_task = sprintf("%.3f (%.3f)", REC_task_mean, REC_task_sd),
    LDI_task = sprintf("%.3f (%.3f)", LDI_task_mean, LDI_task_sd)
  ) %>%
  select(REC_task, LDI_task)

############################################
# 5. Print outputs
############################################

cat("Participant-level MST metrics (Task Only dataset):\n")
print(mst_metrics_task)

cat("\nGroup summary:\n")
print(mst_summary_task)

cat("\nFormatted summary (Mean (SD)):\n")
print(mst_summary_task_formatted)

############################################
# 6. Plot distributions
############################################

mst_metrics_task %>%
  pivot_longer(cols = c(REC_task, LDI_task),
               names_to = "metric",
               values_to = "value") %>%
  ggplot(aes(x = metric, y = value, fill = metric)) +
  geom_boxplot(alpha = 0.7) +
  theme_minimal() +
  labs(
    title = "MST Metrics Distribution (Task Only Dataset)",
    x = "Metric",
    y = "Score"
  ) +
  theme(legend.position = "none")
```

```{r}
library(tidyverse)

############################################
# Combine all experiments
############################################

rec_data <- bind_rows(
  mst_metrics_both %>% mutate(experiment = "Both") %>% select(participant_id, experiment, REC = REC_both),
  mst_metrics_item %>% mutate(experiment = "Item Only") %>% select(participant_id, experiment, REC = REC_item),
  mst_metrics_task %>% mutate(experiment = "Task Only") %>% select(participant_id, experiment, REC = REC_task)
)

ldi_data <- bind_rows(
  mst_metrics_both %>% mutate(experiment = "Both") %>% select(participant_id, experiment, LDI = LDI_both),
  mst_metrics_item %>% mutate(experiment = "Item Only") %>% select(participant_id, experiment, LDI = LDI_item),
  mst_metrics_task %>% mutate(experiment = "Task Only") %>% select(participant_id, experiment, LDI = LDI_task)
)

ggplot(rec_data, aes(x = experiment, y = REC, fill = experiment)) +
  geom_violin(alpha = 0.6) +
  geom_boxplot(width = 0.15, fill = "white") +
  labs(
    title = "Recognition Score (REC) Across Experiments",
    x = "Experiment Type",
    y = "REC Score"
  ) +
  theme_minimal() +
  theme(legend.position = "none")

ggplot(ldi_data, aes(x = experiment, y = LDI, fill = experiment)) +
  geom_violin(alpha = 0.6) +
  geom_boxplot(width = 0.15, fill = "white") +
  labs(
    title = "Lure Discrimination Index (LDI) Across Experiments",
    x = "Experiment Type",
    y = "LDI Score"
  ) +
  theme_minimal() +
  theme(legend.position = "none")

metrics_all <- bind_rows(
  rec_data %>% mutate(metric = "REC") %>% rename(value = REC),
  ldi_data %>% mutate(metric = "LDI") %>% rename(value = LDI)
)
```

