  pivot_longer(cols = c(REC_item, LDI_item),
               names_to = "metric",
               values_to = "value") %>%
  ggplot(aes(x = metric, y = value, fill = metric)) +
  geom_boxplot(alpha = 0.7) +
  theme_minimal() +
  labs(
    title = "MST Metrics Distribution (Item Only Dataset)",
    x = "Metric",
    y = "Score"
  ) +
  theme(legend.position = "none")
